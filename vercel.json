{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET,POST,PUT,DELETE,OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    {
      "src": "/app.js",
      "dest": "public/app.js"
    },
    {
      "src": "/style.css",
      "dest": "public/style.css"
    },
    {
      "src": "/logo.png",
      "dest": "public/logo.png"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
